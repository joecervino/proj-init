{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "engines": {
    "node": "{{DEFAULT_NODE_VERSION}}"
  },
  "dependencies": {
    "fastify": "^5",
    "@fastify/cors": "^10",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "eslint": "^9",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3",
    "@vitest/coverage-v8": "^3"
  }
}
