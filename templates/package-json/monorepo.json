{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api-service dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api-service build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "engines": {
    "node": "{{DEFAULT_NODE_VERSION}}"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
