{{PROJECT_NAME_UPPER}}_ENV="${{{PROJECT_NAME_UPPER}}_ENV:-prod}"
if [ "${{PROJECT_NAME_UPPER}}_ENV" = "dev" ]; then
  export CLOUDSDK_ACTIVE_CONFIG_NAME={{GCP_CONFIG_NAME_DEV}}
  export GCP_PROJECT_ID={{GCP_PROJECT_ID_DEV}}
else
  export CLOUDSDK_ACTIVE_CONFIG_NAME={{GCP_CONFIG_NAME}}
  export GCP_PROJECT_ID={{GCP_PROJECT_ID}}
fi
export PROJECT_ID="$GCP_PROJECT_ID"
export GCP_REGION={{GCP_REGION}}
dotenv_if_exists .env.local
