# {{PROJECT_NAME}} environment variables
# Copy to .env.local and fill in values

# Database
DATABASE_URL=

# API Keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# GCP (set automatically by direnv -- listed here for documentation)
# GCP_PROJECT_ID={{GCP_PROJECT_ID}}
# GCP_REGION={{GCP_REGION}}
# CLOUDSDK_ACTIVE_CONFIG_NAME={{GCP_CONFIG_NAME}}

# Local GCP devcontainer auth (non-secret placeholders)
# Auth priority: impersonation -> WIF -> key (last resort)
GCP_DEV_ME_USER_EMAIL=
GCP_DEV_SA_ID=local-dev-codex
GCP_DEV_IMPERSONATE_SERVICE_ACCOUNT=
GCP_DEV_WIF_CREDENTIAL_FILE=
GCP_DEV_CREDENTIAL_FILE=
